{
  "name": "claude-agent-desktop",
  "private": true,
  "version": "0.9.11",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite",
    "build": "tsc --noEmit && vite build && tauri build",
    "build:web": "tsc --noEmit && vite build",
    "gen:skills": "npx --yes esbuild src/lib/skills/index.ts --bundle --format=esm --platform=node --outfile=.skills-bundle.mjs && node scripts/gen-skill-seed.mjs && node -e \"require('fs').rmSync('.skills-bundle.mjs',{force:true})\"",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.0.1",
    "@tauri-apps/plugin-opener": "^2.2.5",
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "clsx": "^2.1.1",
    "markdown-to-jsx": "^7.7.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/react": "^18.3.13",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "vite": "^6.0.3"
