# agent-server environment (Remote mode).
# Copy to .env on the server (or set in the systemd unit). The desktop app in
# Local mode needs NONE of these — it spawns the `claude` CLI directly.

# --- Required ---
# Shared bearer token gating /api/* and /ws/*. Must be >= 24 chars.
# Generate: openssl rand -base64 36
CAD_SERVER_TOKEN=

# --- Optional ---
# Address the server binds. Default 0.0.0.0:9120. Use 127.0.0.1:9120 or a LAN
# IP (e.g. 10.0.0.84:9120) to avoid exposing it on all interfaces.
CAD_SERVER_BIND=0.0.0.0:9120

# Data dir (state.sqlite, memory.md, skills/). Default ~/.claude-agent-desktop.
# Aliased into CLAUDE_AGENT_DESKTOP_HOME at boot.
CAD_HOME=

# Serve a built web bundle (dist/) as the SPA at /. Point at the dist dir.
CAD_STATIC_DIR=

# Git source tree used by the update badge to compare build vs HEAD.
CAD_SOURCE_DIR=/opt/cad

# The commit the running binary was built from (the deploy script sets this).
CAD_BUILD_COMMIT=

# --- Local dev override (desktop app) ---
# Absolute path to the claude binary if it isn't auto-discovered.
# CLAUDE_BIN=
